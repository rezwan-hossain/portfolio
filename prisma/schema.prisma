generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String        @id @default(uuid())
  authId              String        @unique
  email               String        @unique
  firstName           String?
  lastName            String?
  userName            String?       @unique
  phone               String?
  address             String?
  birthDate           DateTime?
  gender              String?
  image               String?
  role                Role          @default(USER)
  forcePasswordChange Boolean       @default(false)
  isActive            Boolean       @default(true)
  isArchived          Boolean       @default(false)
  isGuest             Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  couponUsages        CouponUsage[]
  orders              Order[]

  @@map("users")
}

model Organizer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]

  @@map("organizers")
}

model Event {
  id              String         @id @default(uuid())
  name            String
  slug            String         @unique
  date            DateTime
  time            DateTime
  address         String
  eventType       EventType      @default(LIVE)
  organizerId     Int
  description     String
  shortDesc       String?        @db.VarChar(255)
  bannerImage     String
  thumbImage      String?
  minPackagePrice Float?
  status          Status         @default(ACTIVE)
  isActive        Boolean        @default(true)
  isArchived      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  coupons         Coupon[]
  organizer       Organizer      @relation(fields: [organizerId], references: [id])
  orders          Order[]
  packages        Package[]
  registrations   Registration[]

  @@map("events")
}

model Package {
  id             Int      @id @default(autoincrement())
  name           String
  distance       String
  price          Int
  availableSlots Int
  usedSlots      Int      @default(0)
  status         Status   @default(ACTIVE)
  isActive       Boolean  @default(true)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  eventId        String
  orders         Order[]
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  coupons        Coupon[] @relation("CouponToPackages")

  @@map("packages")
}

model Order {
  id           String        @id @default(uuid())
  status       OrderStatus   @default(PENDING)
  isActive     Boolean       @default(true)
  isArchived   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  qty          Int           @default(1)
  subtotal     Float         @default(0)
  discount     Float         @default(0)
  total        Float         @default(0)
  userId       String
  packageId    Int
  eventId      String
  couponId     String?
  couponUsage  CouponUsage?
  coupon       Coupon?       @relation(fields: [couponId], references: [id])
  event        Event         @relation(fields: [eventId], references: [id])
  package      Package       @relation(fields: [packageId], references: [id])
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment      Payment?
  registration Registration?

  @@map("orders")
}

model Registration {
  id                     String   @id @default(uuid())
  orderId                String   @unique
  eventId                String
  bibNumber              String?
  fullName               String
  phone                  String
  gender                 String
  birthDate              DateTime
  ageCategory            String
  bloodGroup             String
  tshirtSize             String
  emergencyContactName   String?
  emergencyContactNumber String?
  communityName          String?
  runnerCategory         String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  event                  Event    @relation(fields: [eventId], references: [id])
  order                  Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  email                  String?

  @@unique([eventId, bibNumber])
  @@map("registrations")
}

model Payment {
  id             String        @id @default(uuid())
  amount         Int
  currency       String        @default("BDT")
  status         PaymentStatus @default(PENDING)
  transactionId  String?       @unique
  paymentId      String?       @unique
  paymentMethod  String?
  paymentGateway String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model HeroSection {
  id             String    @id @default(uuid())
  title          String    @default("Run Beyond")
  desktopImage   String
  mobileImage    String?
  slug           String?
  eventDate      DateTime?
  showCountdown  Boolean   @default(true)
  showSlugButton Boolean   @default(true)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("hero_sections")
}

model GalleryImage {
  id        String   @id @default(cuid())
  src       String
  alt       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gallery_images")
}

model Coupon {
  id             String        @id @default(uuid())
  code           String
  discountType   DiscountType  @default(PERCENTAGE)
  discountValue  Float
  maxUses        Int?
  usedCount      Int           @default(0)
  maxUsesPerUser Int           @default(1)
  minOrderAmount Float?
  maxDiscount    Float?
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  eventId        String
  scopeType      CouponScope   @default(EVENT)
  usages         CouponUsage[]
  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders         Order[]
  packages       Package[]     @relation("CouponToPackages")

  @@unique([code, eventId])
  @@map("coupons")
}

model CouponUsage {
  id       String   @id @default(uuid())
  discount Float
  usedAt   DateTime @default(now())
  couponId String
  userId   String
  orderId  String   @unique
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@map("coupon_usages")
}

model TeamMember {
  id           String       @id @default(uuid())
  name         String
  role         String?
  bio          String?
  image        String?
  sortOrder    Int          @default(0)
  category     TeamCategory @default(ADVISOR)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  linkedinUrl  String?
  twitterUrl   String?
  githubUrl    String?
  instagramUrl String?
  facebookUrl  String?

  @@map("team_members")
}

enum Role {
  USER
  ADMIN
  ORGANIZER
}

enum EventType {
  LIVE
  VIRTUAL
}

enum Status {
  ACTIVE
  INACTIVE
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CouponScope {
  EVENT
  PACKAGE
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TeamCategory {
  ADMIN
  ADVISOR
  ORGANIZER
}
