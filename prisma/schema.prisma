// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER ───────────────────────────────────────────
model User {
  id                  String    @id @default(uuid())
  authId              String    @unique // 👈 Supabase auth.users id
  email               String    @unique
  firstName           String?
  lastName            String?
  userName            String?   @unique
  phone               String?
  address             String?
  birthDate           DateTime?
  gender              String?
  image               String?
  role                Role      @default(USER)
  forcePasswordChange Boolean   @default(false)
  isActive            Boolean   @default(true)
  isArchived          Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders       Order[]
  couponUsages CouponUsage[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
  ORGANIZER
}

// ─── ORGANIZER ───────────────────────────────────────────

model Organizer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]

  @@map("organizers")
}

// ─── EVENT ──────────────────────────────────────────
model Event {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  date            DateTime
  time            DateTime
  address         String
  eventType       EventType @default(LIVE)
  organizerId     Int
  organizer       Organizer @relation(fields: [organizerId], references: [id])
  description     String    @db.Text
  shortDesc       String?   @db.VarChar(255)
  bannerImage     String
  thumbImage      String?
  minPackagePrice Float?
  status          Status    @default(ACTIVE)
  isActive        Boolean   @default(true)
  isArchived      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  packages      Package[]
  orders        Order[]
  registrations Registration[]
  coupons       Coupon[]

  @@map("events")
}

enum EventType {
  LIVE
  VIRTUAL
}

enum Status {
  ACTIVE
  INACTIVE
  CANCELLED
  COMPLETED
}

// ─── PACKAGE ────────────────────────────────────────
model Package {
  id             Int      @id @default(autoincrement())
  name           String
  distance       String
  price          Int
  availableSlots Int
  usedSlots      Int      @default(0)
  status         Status   @default(ACTIVE)
  isActive       Boolean  @default(true)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@map("packages")
}

// ─── ORDER ──────────────────────────────────────────
model Order {
  id         String      @id @default(uuid())
  status     OrderStatus @default(PENDING)
  isActive   Boolean     @default(true)
  isArchived Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  qty        Int         @default(1)

  subtotal Float @default(0)
  discount Float @default(0)
  total    Float @default(0)


  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  packageId Int
  package   Package @relation(fields: [packageId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  registration Registration?
  payment      Payment?
  couponUsage  CouponUsage?

  @@map("orders")
}

model Registration {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  eventId   String // ← ADD
  event     Event   @relation(fields: [eventId], references: [id]) // ← ADD
  bibNumber String? // ← ADD

  fullName  String
  phone     String
  gender    String
  birthDate DateTime

  ageCategory String
  bloodGroup  String
  tshirtSize  String

  emergencyContactName   String?
  emergencyContactNumber String?

  communityName  String?
  runnerCategory String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, bibNumber])
  @@map("registrations")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// ─── PAYMENT ────────────────────────────────────────
model Payment {
  id             String        @id @default(uuid())
  amount         Int
  currency       String        @default("BDT")
  status         PaymentStatus @default(PENDING)
  transactionId  String?       @unique
  paymentId      String?       @unique // bKash internal payment ID
  paymentMethod  String?
  paymentGateway String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model HeroSection {
  id             String    @id @default(uuid())
  title          String    @default("Run Beyond")
  desktopImage   String
  mobileImage    String?
  slug           String?
  eventDate      DateTime?
  showCountdown  Boolean   @default(true)
  showSlugButton Boolean   @default(true)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("hero_sections")
}

model GalleryImage {
  id        String   @id @default(cuid())
  src       String
  alt       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gallery_images")
}

// ─── COUPON ─────────────────────────────────────────
model Coupon {
  id             String       @id @default(uuid())
  code           String
  discountType   DiscountType @default(PERCENTAGE)
  discountValue  Float // 10 for 10% or 100 for ৳100
  maxUses        Int? // null = unlimited
  usedCount      Int          @default(0)
  maxUsesPerUser Int          @default(1)
  minOrderAmount Float?
  maxDiscount    Float? // Cap for percentage discounts
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  usages CouponUsage[]

  @@unique([code, eventId])
  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model CouponUsage {
  id       String   @id @default(uuid())
  discount Float
  usedAt   DateTime @default(now())

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@map("coupon_usages")
}
